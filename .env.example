# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-...
# Model mặc định: anthropic/claude-sonnet-4-5
# Các model khác: google/gemini-flash-1.5 | meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Zalo OA
ZALO_OA_ACCESS_TOKEN=your_oa_access_token
ZALO_APP_SECRET=your_app_secret

# Server
PORT=8000
